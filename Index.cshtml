@model GoldPriceTracker.Models.GoldPriceViewModel
@{
    ViewData["Title"] = "Gold Price Tracker";
    Layout = null; // No layout for this simple example
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <!-- Auto-refresh every 30 seconds -->
    <meta http-equiv="refresh" content="30">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            text-align: center;
            margin-top: 50px;
            background-color: #f8f9fa;
        }
        .container {
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            padding: 30px;
            max-width: 400px;
            margin: 0 auto;
        }
        .price {
            font-size: 2.5em;
            font-weight: bold;
            color: #d4af37; /* Gold color */
            margin: 20px 0;
        }
        .up { color: #28a745; font-weight: bold; }
        .down { color: #dc3545; font-weight: bold; }
        .unchanged { color: #6c757d; font-weight: bold; }
        .updated-time {
            font-size: 0.9em;
            color: #6c757d;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Gold Price (24K, 10g)</h1>
        @if (Model.PricePer10gInr > 0)
        {
            <div class="price">₹ @((Model.PricePer10gInr / 0.9167m).ToString("N2"))</div>

            @if (Model.Status == "UP")
            {
                <div class="up">
                    ▲ Status: UP | +@Model.ChangePercentage.ToString("F2")%
                </div>
            }
            else if (Model.Status == "DOWN")
            {
                <div class="down">
                    ▼ Status: DOWN | -@Model.ChangePercentage.ToString("F2")%
                </div>
            }
            else
            {
                <div class="unchanged">
                    ▬ Status: UNCHANGED
                </div>
            }

            <div class="updated-time">
                Last Updated: @Model.LastUpdated.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss")
            </div>
        }
        else
        {
            <div class="price">Loading...</div>
            <div class="unchanged">Waiting for gold price data.</div>
        }
    </div>
</body>
</html>
